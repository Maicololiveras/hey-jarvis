# ─── API Keys (at least one required for cloud LLM routing) ──────────
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Jarvis Backend ─────────────────────────────────────────────────
BACKEND_PORT=50052
WHISPER_MODEL_SIZE=base
LOG_LEVEL=INFO

# ─── Maix AI Engine ─────────────────────────────────────────────────
MAIX_PORT=50051
MAIX_MODELS_DIR=D:/LM WEG/python/models
MAIX_MODEL_FILE=model.gguf
MAIX_CONFIG=D:/LM WEG/python/config.yaml
N_GPU_LAYERS=0
N_CTX=4096

# ─── CUDA (set for GPU-accelerated llama-cpp-python) ────────────────
# CMAKE_ARGS=-DGGML_CUDA=on
